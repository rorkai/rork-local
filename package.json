{
  "name": "rork-local",
  "version": "0.1.0",
  "description": "Localhost Rork-style app preview: iOS simulator in the browser + one-click publish via asc",
  "type": "module",
  "license": "Apache-2.0",
  "bin": {
    "rork-local": "./dist/cli.js"
  },
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "files": [
    "dist/",
    "public/",
    "skills/"
  ],
  "keywords": [
    "ios",
    "simulator",
    "app-store-connect",
    "testflight",
    "asc"
  ],
  "scripts": {
    "build": "bun build src/cli.ts src/server.ts --target node --outdir dist --packages external --tsconfig-override tsconfig.build.json && tsc --emitDeclarationOnly",
    "typecheck": "tsc --noEmit",
    "dev": "bun run src/cli.ts",
    "start": "node dist/cli.js",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "express": "^5.1.0",
    "serve-sim": "^0.1.44"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "typescript": "^5.9.3"
  }
}
